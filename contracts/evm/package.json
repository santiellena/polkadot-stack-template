{
  "name": "aperio-evm",
  "version": "0.1.0",
  "description": "EVM deployment of the Aperio repository registry using Hardhat, solc, and viem",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
	"scripts": {
		"compile": "npx hardhat compile",
		"test": "npx hardhat test",
		"deploy:local": "npx hardhat run scripts/deploy.ts --network local",
		"deploy:testnet": "npx hardhat run scripts/deploy.ts --network polkadotTestnet",
		"verify": "npx hardhat verify --network polkadotTestnet",
		"fmt": "prettier --write 'contracts/**/*.sol' 'scripts/**/*.ts' 'test/**/*.ts' hardhat.config.ts",
		"fmt:check": "prettier --check 'contracts/**/*.sol' 'scripts/**/*.ts' 'test/**/*.ts' hardhat.config.ts"
	},
  "devDependencies": {
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@nomicfoundation/hardhat-viem": "^2.0.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "chai": "^4.3.0",
    "hardhat": "^2.27.0",
    "prettier": "^3.8.1",
    "prettier-plugin-solidity": "^2.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "viem": "^2.0.0"
  }
}
